# ── Flight Data ──────────────────────────
SERPAPI_KEY=                          # serpapi.com → Dashboard → API Key (250 free/month)
KIWI_API_KEY=                         # (unused, optional — Kiwi.com Tequila API)
KIWI_API_BASE=https://api.tequila.kiwi.com

# ── AI APIs ──────────────────────────────
ANTHROPIC_API_KEY=                    # console.anthropic.com → API Keys (primary planner AI)
OPENAI_API_KEY=                       # platform.openai.com → API Keys (fallback for planner)

# ── GoHighLevel V1 (CRM, contacts, pipelines) ──
GHL_API_KEY=                          # GHL → Settings → API Keys
GHL_API_BASE=https://rest.gohighlevel.com/v1
GHL_LOCATION_ID=                      # GHL → Settings → Business Profile → Location ID
GHL_PIPELINE_ID=                      # GHL → Opportunities → "SALTY Explorer" pipeline ID
GHL_STAGE_QUIZ_LEAD=                  # Stage ID: "Quiz Lead"
GHL_STAGE_EXPLORING=                  # Stage ID: "Exploring"
GHL_STAGE_HIGH_INTENT=                # Stage ID: "High Intent"
GHL_STAGE_BOOKED=                     # Stage ID: "Booked"
GHL_QUIZ_TAG_PREFIX=quiz_
GHL_FLIGHT_TAG_PREFIX=flight_

# ── GoHighLevel V2 (Conversations / Email API) ──
GHL_V2_API_BASE=https://services.leadconnectorhq.com
GHL_V2_API_TOKEN=                     # GHL → Settings → Integrations → V2 Token
GHL_FROM_EMAIL=hello@getsaltyretreats.com

# ── Cron & Storage ──────────────────────
CRON_SECRET=                          # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KV_REST_API_URL=                      # Vercel → Storage → KV → REST URL
KV_REST_API_TOKEN=                    # Vercel → Storage → KV → REST Token
